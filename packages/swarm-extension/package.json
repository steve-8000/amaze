{
	"type": "module",
	"name": "@amaze/swarm-extension",
	"version": "3.1.0",
	"description": "Swarm orchestration extension for amaze",
	"homepage": "https://amaze",
	"author": "Derek Rynd",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/amaze-agent.git",
		"directory": "packages/swarm-extension"
	},
	"bugs": {
		"url": "https://github.com/can1357/amaze-agent/issues"
	},
	"keywords": [
		"swarm",
		"orchestration",
		"agent",
		"extension"
	],
	"bin": {
		"amaze-swarm": "src/cli.ts"
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@amaze/pi-utils": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14"
	},
	"peerDependencies": {
		"@amaze/pi-coding-agent": "^3.1.0"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"amaze": {
		"extensions": [
			"./src/extension.ts"
		]
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md"
	]
}
