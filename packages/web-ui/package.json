{
	"name": "@earendil-works/pi-web-ui",
	"private": true,
	"version": "2026.6.16-2",
	"description": "Reusable web UI components for AI chat interfaces powered by @earendil-works/pi-ai",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"engines": {
		"node": ">=24.0.0"
	},
	"exports": {
		".": "./dist/index.js",
		"./app.css": "./dist/app.css"
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsc -p tsconfig.build.json && node scripts/tailwindcss.mjs -i ./src/app.css -o ./dist/app.css --minify",
		"dev": "concurrently --names \"build,example\" --prefix-colors \"cyan,green\" \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"node scripts/tailwindcss.mjs -i ./src/app.css -o ./dist/app.css --watch\" \"npm run dev --prefix example\"",
		"dev:tsc": "concurrently --names \"build\" --prefix-colors \"cyan\" \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"node scripts/tailwindcss.mjs -i ./src/app.css -o ./dist/app.css --watch\"",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit && npm run check --prefix example"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "^2026.6.16-2",
		"@earendil-works/pi-ai": "^2026.6.16-2",
		"@lmstudio/sdk": "1.5.0",
		"docx-preview": "0.3.7",
		"highlight.js": "11.11.1",
		"jszip": "3.10.1",
		"lucide": "0.544.0",
		"ollama": "0.6.3",
		"pdfjs-dist": "5.4.394",
		"typebox": "1.1.38",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	},
	"peerDependencies": {
		"@mariozechner/mini-lit": "^0.2.0",
		"lit": "^3.3.1"
	},
	"devDependencies": {
		"@mariozechner/mini-lit": "0.2.1",
		"@tailwindcss/cli": "4.3.0",
		"concurrently": "9.2.1",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3"
	},
	"keywords": [
		"ai",
		"chat",
		"ui",
		"components",
		"llm",
		"web-components",
		"mini-lit"
	],
	"author": "Mario Zechner",
	"license": "MIT"
}
