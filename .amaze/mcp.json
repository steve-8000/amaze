{
	"$schema": "https://raw.githubusercontent.com/can1357/amaze/main/packages/coding-agent/src/config/mcp-schema.json",
	"mcpServers": {
		"amaze-browser-bridge": {
			"type": "stdio",
			"command": "bun",
			"args": [
				"packages/browser-control-extension/src/mcp-server.ts"
			],
			"cwd": ".",
			"enabled": false
		},
		"chrome-devtools": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp@latest"
			],
			"cwd": ".",
			"enabled": false
		}
	}
}
