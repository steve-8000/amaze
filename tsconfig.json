{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": [
				"./*"
			],
			"@steve-8000/amaze-ai": [
				"./packages/ai/src/index.ts"
			],
			"@steve-8000/amaze-ai/oauth": [
				"./packages/ai/src/oauth.ts"
			],
			"@steve-8000/amaze-ai/*": [
				"./packages/ai/src/*.ts",
				"./packages/ai/src/providers/*.ts"
			],
			"@steve-8000/amaze-ai/dist/*": [
				"./packages/ai/src/*"
			],
			"@steve-8000/amaze-agent-core": [
				"./packages/agent/src/index.ts"
			],
			"@steve-8000/amaze-agent-core/*": [
				"./packages/agent/src/*"
			],
			"amaze": [
				"./packages/coding-agent/src/index.ts"
			],
			"amaze/*": [
				"./packages/coding-agent/src/*"
			],
			"typebox": [
				"./node_modules/typebox"
			],
			"@steve-8000/amaze-tui": [
				"./packages/tui/src/index.ts"
			],
			"@steve-8000/amaze-tui/*": [
				"./packages/tui/src/*"
			],
			"@steve-8000/amaze-web-ui": [
				"./packages/web-ui/src/index.ts"
			],
			"@steve-8000/amaze-web-ui/*": [
				"./packages/web-ui/src/*"
			],
			"@steve-8000/amaze-agent-old": [
				"./packages/agent-old/src/index.ts"
			],
			"@steve-8000/amaze-agent-old/*": [
				"./packages/agent-old/src/*"
			],
		}
	},
	"include": [
		"packages/*/src/**/*",
		"packages/*/test/**/*",
		"packages/coding-agent/examples/**/*"
	],
	"exclude": [
		"packages/web-ui/**/*",
		"**/dist/**",
		"packages/coding-agent/examples/extensions/gondolin/**"
	]
}
