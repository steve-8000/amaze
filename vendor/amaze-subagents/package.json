{
  "name": "amaze-subagents",
  "version": "0.26.0",
  "description": "Pi extension for delegating tasks to subagents with chains, parallel execution, and TUI clarification",
  "author": "Nico Bailon",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicobailon/amaze-subagents.git"
  },
  "homepage": "https://github.com/nicobailon/amaze-subagents#readme",
  "bugs": {
    "url": "https://github.com/nicobailon/amaze-subagents/issues"
  },
  "keywords": [
    "amaze-package",
    "pi",
    "amaze",
    "subagents",
    "ai",
    "agents",
    "cli"
  ],
  "bin": {
    "amaze-subagents": "install.mjs"
  },
  "files": [
    "src/**/*.ts",
    "*.mjs",
    "agents/",
    "skills/**/*",
    "prompts/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test test/unit/*.test.ts",
    "test:integration": "node --import jiti/register --import ./test/support/register-loader.mjs --test test/integration/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration"
  },
  "amaze": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@steve-8000/amaze-agent-core": "*",
    "@steve-8000/amaze-ai": "*",
    "amaze": "*"
  },
  "peerDependenciesMeta": {
    "@steve-8000/amaze-agent-core": {
      "optional": true
    },
    "@steve-8000/amaze-ai": {
      "optional": true
    },
    "amaze": {
      "optional": true
    }
  },
  "dependencies": {
    "@steve-8000/amaze-tui": "^0.74.0",
    "jiti": "^2.7.0",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@steve-8000/amaze-agent-core": "^0.74.0",
    "@steve-8000/amaze-ai": "^0.74.0",
    "amaze": "^0.74.0"
  }
}
