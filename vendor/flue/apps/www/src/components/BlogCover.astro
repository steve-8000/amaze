---
// Hero cover ported from the docs "why-flue" page (DocsCover, "workflows"
// variant): a paper-grid panel with a dithering "sphere" shader. Uses the
// existing www ambient-shader engine (`setupHomepageShaders`).
---

<div class="relative mb-8 flex h-[200px] items-center justify-center overflow-hidden rounded-sm border border-slate-300 bg-[#e9eef4] max-[760px]:mb-6 max-[760px]:h-[168px]" aria-hidden="true">
	<svg class="absolute inset-0 size-full">
		<defs>
			<pattern id="blogCoverGrid" width="20" height="20" patternUnits="userSpaceOnUse">
				<path d="M20 0H0V20" fill="none" stroke="#64748b" stroke-opacity="0.72" stroke-width="0.8" stroke-dasharray="1 2" />
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill="url(#blogCoverGrid)" />
	</svg>
	<div
		class="pattern-layer relative z-10 size-[144px] rounded-full max-[760px]:size-[128px]"
		style="--shadow-rgb: 59 130 246;"
		data-ambient-shader
		data-color-back="#00000000"
		data-color-front="#3b82f6"
		data-shape="sphere"
		data-type="4x4"
		data-size="2"
		data-scale="1.02"
		data-speed="0.18"
	></div>
</div>

<script>
	import { setupHomepageShaders } from '../homepage-shaders';

	setupHomepageShaders();
</script>
