{
	"name": "apps-docs",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"build": "rm -rf ./dist && astro build && mv ./dist/docs/_redirects ./dist/_redirects && pagefind --site ./dist/docs",
		"preview": "astro preview",
		"deploy": "pnpm run build && pnpm exec wrangler deploy",
		"astro": "astro",
		"check": "astro check",
		"check:types": "astro check"
	},
	"dependencies": {
		"@astrojs/mdx": "7.0.0-beta.2",
		"@paper-design/shaders": "0.0.76",
		"@tailwindcss/vite": "^4.2.0",
		"astro": "7.0.0-beta.3",
		"tailwindcss": "^4.2.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"pagefind": "^1.5.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.14",
		"wrangler": "^4.97.0"
	}
}
