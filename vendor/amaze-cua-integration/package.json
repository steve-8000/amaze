{
	"name": "amaze-cua-integration",
	"version": "0.1.0",
	"description": "Cua (trycua/cua) computer-use integration for the amaze coding agent. Exposes Cua sandboxes (local Docker/QEMU/Lume) and unsandboxed localhost control as skills plus tools, with local mode as the default and an opt-in cloud mode.",
	"type": "module",
	"license": "MIT",
	"author": "Yeongyu Kim",
	"homepage": "https://github.com/code-yeongyu/amaze-cua-integration",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-yeongyu/amaze-cua-integration.git"
	},
	"bugs": {
		"url": "https://github.com/code-yeongyu/amaze-cua-integration/issues"
	},
	"keywords": [
		"pi",
		"pi-mono",
		"amaze",
		"pi-extension",
		"amaze",
		"cua",
		"trycua",
		"computer-use",
		"sandbox",
		"automation",
		"agent",
		"typescript"
	],
	"amaze": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"schema",
		"skills",
		"python",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"NOTICE"
	],
	"scripts": {
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:integration": "vitest --run test/integration --passWithNoTests",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsgo --noEmit && biome check .",
		"generate:schema": "node scripts/generate-schema.mjs"
	},
	"peerDependencies": {
		"amaze": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/node": "^25.9.3",
		"@typescript/native-preview": "^7.0.0-dev.20260609.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
